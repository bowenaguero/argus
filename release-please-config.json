{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "argus",
      "version-file": "pyproject.toml",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "refactor",
          "section": "Refactoring"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "chore",
          "section": "Miscellaneous",
          "hidden": true
        },
        {
          "type": "ci",
          "section": "CI",
          "hidden": true
        }
      ]
    }
  }
}
